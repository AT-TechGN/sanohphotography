# ──────────────────────────────────────────────────────────────────────────────
# CONFIGURATION LOCALE — Copiez ce fichier en .env.local et adaptez les valeurs
# Le fichier .env.local n'est PAS commité (déjà dans .gitignore)
# ──────────────────────────────────────────────────────────────────────────────

# ── Base de données ────────────────────────────────────────────────────────────
# MySQL / MariaDB (WAMP sur Windows)
DATABASE_URL="mysql://root:@127.0.0.1:3306/sanohphotography?serverVersion=8.0.32&charset=utf8mb4"

# MariaDB (si la version de WAMP utilise MariaDB)
# DATABASE_URL="mysql://root:@127.0.0.1:3306/sanohphotography?serverVersion=mariadb-10.4.28&charset=utf8mb4"

# PostgreSQL (Linux/Mac)
# DATABASE_URL="postgresql://postgres:password@127.0.0.1:5432/sanohphotography?serverVersion=16&charset=utf8"

# ── Serveur ────────────────────────────────────────────────────────────────────
# URL publique du serveur (pour construire les URLs des photos uploadées)
APP_URL=http://localhost:8000

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=SanohPhotographySecretKey2024
